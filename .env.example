# ========== 服务端口 ==========
PORT=3001

# ========== JWT 密钥 ==========
JWT_SECRET=your-jwt-secret-here

# ========== AI 配置 ==========
# 必填：你的 API Key
OPENAI_API_KEY=your-api-key-here

# API 地址（兼容 OpenAI 格式即可）
# OpenAI 官方：https://api.openai.com/v1
# DeepSeek：   https://api.deepseek.com/v1
# 智谱 AI：    https://open.bigmodel.cn/api/paas/v4
# 通义千问：    https://dashscope.aliyuncs.com/compatible-mode/v1
# 火山方舟：    https://ark.cn-beijing.volces.com/api/v3
API_BASE_URL=https://api.openai.com/v1

# 模型名称
# DeepSeek: deepseek-chat / deepseek-reasoner
# OpenAI: gpt-3.5-turbo / gpt-4o / gpt-4o-mini
# 智谱: glm-4-flash / glm-4-plus
# 火山方舟 DeepSeek: DeepSeek-V4-flash / DeepSeek-V3 / Doubao-1.5-lite-32k
MODEL_NAME=gpt-3.5-turbo

# ========== TTS 语音合成配置 ==========
# 豆包语音合成 App ID / Access Token
TTS_APP_ID=your-tts-app-id
TTS_ACCESS_TOKEN=your-tts-access-token
TTS_SECRET_KEY=your-tts-secret-key

# 语音合成 API 地址（V3）
TTS_API_URL=https://openspeech.bytedance.com/api/v3/tts/unidirectional

# 集群名称
TTS_CLUSTER=volcano_tts

# 资源ID（V3接口必需，TTS 2.0需要seed-tts-2.0）
TTS_RESOURCE_ID=seed-tts-2.0

# 默认音色
TTS_VOICE_TYPE=zh_female_vv_uranus_bigtts

# 可选音色列表（JSON格式，2男2女不同风格）
# 拟人化名字：小暖(温柔女声)、知秋(知性女声)、阿沉(沉稳男声)、深言(深情男声)
TTS_VOICES=[{"id":"xiaonuan","name":"小暖","label":"温柔女声","gender":"female","style":"温柔治愈","voice_type":"zh_female_vv_uranus_bigtts","avatar":"/avatars/xiaonuan.jpg"},{"id":"zhiqiu","name":"知秋","label":"知性女声","gender":"female","style":"知性温暖","voice_type":"zh_female_cancan_uranus_bigtts","avatar":"/avatars/zhiqiu.jpg"},{"id":"achen","name":"阿沉","label":"沉稳男声","gender":"male","style":"沉稳可靠","voice_type":"zh_male_yunzhou_uranus_bigtts","avatar":"/avatars/achen.jpg"},{"id":"shenyan","name":"深言","label":"深情男声","gender":"male","style":"深情内敛","voice_type":"zh_male_qingcang_uranus_bigtts","avatar":"/avatars/shenyan.jpg"}]